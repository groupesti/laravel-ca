{
    "name": "groupesti/laravel-ca",
    "description": "Modular Certificate Authority system for Laravel - Core Package",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "phpseclib/phpseclib": "^3.0",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/encryption": "^12.0",
        "illuminate/routing": "^12.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\CaServiceProvider"
            ],
            "aliases": {
                "Ca": "CA\\Facades\\Ca"
            }
        }
    },
    "minimum-stability": "stable"
}
